---
interface Props {
  name: string;
  icon: string;
}

const { name, icon } = Astro.props;
---

<div class="stack-tile" title={name}>
  <span class="stack-tile__icon" aria-hidden="true" set:html={icon} />
  <span class="stack-tile__name mono-to-brand">{name}</span>
</div>

<style>
  .stack-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 14px 12px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--card-fill);
    min-width: 72px;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    cursor: default;
  }

  .stack-tile:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
    transform: translateY(-3px);
  }

  .stack-tile__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .stack-tile__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .stack-tile__name {
    font-size: 0.65rem;
    white-space: nowrap;
  }
</style>
