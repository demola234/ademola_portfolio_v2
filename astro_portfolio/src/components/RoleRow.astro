---
interface Props {
  company: string;
  role: string;
  dateRange: string;
  location: string;
  bullets: string[];
  stack: string[];
  isLast?: boolean;
}

const { company, role, dateRange, location, bullets, stack, isLast = false } = Astro.props;
---

<div class={`role-row ${isLast ? 'role-row--last' : ''}`}>
  <!-- Timeline spine -->
  <div class="role-row__spine" aria-hidden="true">
    <div class="role-row__dot" />
    {!isLast && <div class="role-row__line" />}
  </div>

  <!-- Content -->
  <div class="role-row__body">
    <div class="role-row__header">
      <div>
        <p class="role-row__company">{company}</p>
        <h3 class="role-row__role">{role}</h3>
      </div>
      <div class="role-row__meta">
        <span class="role-row__date mono-to-brand">{dateRange}</span>
        <span class="role-row__location mono-to-brand">{location}</span>
      </div>
    </div>

    <ul class="role-row__bullets">
      {bullets.map((b) => (
        <li class="role-row__bullet">
          <span class="role-row__bullet-marker text-accent" aria-hidden="true">▸</span>
          {b}
        </li>
      ))}
    </ul>

    <div class="role-row__stack">
      {stack.map((s) => (
        <span class="tag">{s}</span>
      ))}
    </div>
  </div>
</div>

<style>
  .role-row {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 0 20px;
    padding-bottom: 48px;
  }

  .role-row--last {
    padding-bottom: 0;
  }

  /* Spine */
  .role-row__spine {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 4px;
  }

  .role-row__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: var(--bg);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .role-row__line {
    flex: 1;
    width: 1px;
    background: var(--border);
    margin-top: 6px;
  }

  /* Body */
  .role-row__body {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .role-row__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }

  .role-row__company {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .role-row__role {
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .role-row__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
  }

  .role-row__date,
  .role-row__location {
    font-size: 0.75rem;
    white-space: nowrap;
  }

  /* Bullets */
  .role-row__bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .role-row__bullet {
    display: flex;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .role-row__bullet-marker {
    font-size: 0.7rem;
    margin-top: 5px;
    flex-shrink: 0;
  }

  /* Stack */
  .role-row__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  @media (max-width: 640px) {
    .role-row__header {
      flex-direction: column;
    }
    .role-row__meta {
      align-items: flex-start;
    }
  }
</style>
